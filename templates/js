// EventoSuite — Service Worker v1.0
// Modo: siempre con internet (sin caché offline)
// Para habilitar offline en el futuro, agrega lógica de caché aquí

const VERSION = "eventosuite-v1";

// Instalación — no cachea nada, solo se registra
self.addEventListener("install", event => {
  self.skipWaiting();
});

// Activación — limpia versiones antiguas si las hay
self.addEventListener("activate", event => {
  event.waitUntil(
    caches.keys().then(keys =>
      Promise.all(
        keys
          .filter(key => key !== VERSION)
          .map(key => caches.delete(key))
      )
    ).then(() => self.clients.claim())
  );
});

// Fetch — pasa todo al servidor (sin interceptar)
// Cuando quieras agregar offline, reemplaza esto con lógica de caché
self.addEventListener("fetch", event => {
  event.respondWith(fetch(event.request));
});